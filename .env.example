# --- LLM (DeepSeek через OpenRouter) ---
OPENROUTER_API_KEY=sk-or-v1-...
LLM_MODEL=deepseek/deepseek-chat
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000

# Опционально: заголовки для рейтинга на openrouter.ai
OPENROUTER_HTTP_REFERER=https://your-domain.com
OPENROUTER_X_TITLE=RAG Agent

# --- Аутентификация и регистрация ---
# Bootstrap первого админа: если в БД ещё нет ни одного пользователя, на старте
# будет создан админ с этими credentials. После первого входа — поменяйте пароль
# через UI и оставьте поля пустыми, чтобы случайно не пересоздать.
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change_me_please_at_least_10_chars

# Сессии (cookie-based)
SESSION_COOKIE_NAME=rag_session
SESSION_LIFETIME_DAYS=7
# В deploy через Caddy/HTTPS — true. Для локального http://localhost — false.
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax

# CORS — пусто = same-origin only. Несколько доменов через запятую.
CORS_ORIGINS=

# Регистрация
ALLOW_PUBLIC_REGISTRATION=true
PASSWORD_MIN_LENGTH=10

# Защита от brute force
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_REGISTER_PER_HOUR=5

# --- Пути ---
DATA_DIR=./data

# --- Embedding ---
# По умолчанию — BGE-M3 (~2 GB RAM, лучшее качество, поддержка длинных текстов
# до 8192 токенов и хорошее качество на русском).
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_BATCH_SIZE=16
EMBEDDING_USE_FP16=true
EMBEDDING_QUERY_PREFIX=
EMBEDDING_PASSAGE_PREFIX=
EMBEDDING_MAX_LENGTH=8192

# === LITE режим для серверов 4 GB RAM ===
# Раскомментируйте ВМЕСТО блока выше:
# EMBEDDING_MODEL=intfloat/multilingual-e5-small
# EMBEDDING_BATCH_SIZE=32
# EMBEDDING_USE_FP16=false
# EMBEDDING_QUERY_PREFIX=query:
# EMBEDDING_PASSAGE_PREFIX=passage:
# EMBEDDING_MAX_LENGTH=512
# Расход RAM с этой моделью ~500 MB вместо ~2 GB. Качество retrieval чуть хуже
# на длинных русских текстах (особенно при сложных формулировках), но для 30-40
# документов общим объёмом до 500 страниц работает достойно.

# --- Чанкинг ---
CHUNK_SIZE=2400
CHUNK_OVERLAP=400

# --- Поиск ---
SEARCH_TOP_K=7
SEARCH_USE_BM25=false

# --- Лимиты ---
MAX_FILE_SIZE_MB=50
MAX_DOCUMENTS=100
MAX_HISTORY_MESSAGES=8

# --- Сервер ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# --- OCR ---
OCR_LANGUAGES=rus+eng
OCR_MIN_CHARS_PER_PAGE=100

# --- LLM (DeepSeek через OpenRouter) ---
OPENROUTER_API_KEY=sk-or-v1-...
LLM_MODEL=deepseek/deepseek-chat
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000

# Опционально: заголовки для рейтинга на openrouter.ai
OPENROUTER_HTTP_REFERER=https://your-domain.com
OPENROUTER_X_TITLE=RAG Agent

# --- Аутентификация и регистрация ---
# Bootstrap первого админа: если в БД ещё нет ни одного пользователя, на старте
# будет создан админ с этими credentials. После первого входа — поменяйте пароль
# через UI и оставьте поля пустыми, чтобы случайно не пересоздать.
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change_me_please_at_least_10_chars

# Сессии (cookie-based)
SESSION_COOKIE_NAME=rag_session
SESSION_LIFETIME_DAYS=7
# В deploy через Caddy/HTTPS — true. Для локального http://localhost — false.
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax

# CORS — пусто = same-origin only. Несколько доменов через запятую.
CORS_ORIGINS=

# Регистрация
ALLOW_PUBLIC_REGISTRATION=true
PASSWORD_MIN_LENGTH=10

# Защита от brute force
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_REGISTER_PER_HOUR=5

# --- Пути ---
DATA_DIR=./data

# --- Embedding ---
# По умолчанию — Yandex AI Studio (cloud, ~50 MB RAM, хорошее качество русского).
# Альтернатива — bge (локальный BGE-M3 / e5; +3 GB зависимостей,
# +2 GB RAM, нужен pip install -r requirements-bge-fallback.txt).
EMBEDDING_PROVIDER=yandex

# --- Yandex AI Studio (provider=yandex) ---
# Получить:
#   1. console.yandex.cloud → создать облако и каталог (folder)
#   2. IAM → Сервисные аккаунты → создать аккаунт в этом каталоге
#   3. Выдать роль `ai.languageModels.user`
#   4. У созданного аккаунта → создать API-ключ (показывается один раз)
#   5. Folder ID — в URL/настройках каталога
YANDEX_API_KEY=AQVN...replace_me
YANDEX_FOLDER_ID=b1g...replace_me
# АСИММЕТРИЧНЫЕ модели — НЕ путать местами! Yandex обучил их специально
# для retrieval: одна для индексации документов, другая для запросов.
YANDEX_EMBEDDING_DOC_MODEL=text-search-doc
YANDEX_EMBEDDING_QUERY_MODEL=text-search-query
# 0 = использовать default (256). Можно понизить до 64-128 ради цены/скорости.
YANDEX_EMBEDDING_DIMENSIONS=0
# Защита от throttle. Yandex не публикует точный лимит — берём консервативно.
YANDEX_EMBEDDING_RPM=600
# Yandex embedding context — 2048 токенов (≈ 6000 русских символов). Длиннее
# текст будет обрезан сервером без предупреждения.
YANDEX_EMBEDDING_MAX_CHARS=6000

# --- BGE-M3 / e5 fallback (provider=bge) ---
# Используется ТОЛЬКО если EMBEDDING_PROVIDER=bge.
# Сначала: pip install -r requirements-bge-fallback.txt
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_BATCH_SIZE=16
EMBEDDING_USE_FP16=true
EMBEDDING_QUERY_PREFIX=
EMBEDDING_PASSAGE_PREFIX=
EMBEDDING_MAX_LENGTH=8192

# Альтернатива в режиме bge — multilingual-e5-small для серверов 4 GB:
#   EMBEDDING_MODEL=intfloat/multilingual-e5-small
#   EMBEDDING_QUERY_PREFIX=query:
#   EMBEDDING_PASSAGE_PREFIX=passage:
#   EMBEDDING_MAX_LENGTH=512

# --- Чанкинг ---
CHUNK_SIZE=2400
CHUNK_OVERLAP=400
# Адаптивный размер чанков под тип документа (xlsx/csv → короче, длинные PDF →
# длиннее). Выключи (=false), если хочешь жёстко детерминированный сплит.
CHUNK_ADAPTIVE=true
# Семантический чанкинг: между параграфами считаем cosine эмбеддингов и
# режем там, где смысл реально меняется. Платится индексным временем
# (≈ +1 эмбеддинг на параграф). Включай, если индексация одноразовая, а
# качество retrieval критично.
CHUNK_SEMANTIC=false
CHUNK_SEMANTIC_THRESHOLD=0.55

# --- Поиск ---
SEARCH_TOP_K=7
# BM25 поверх dense. По умолчанию включён: сильно помогает на запросах с
# датами, артикулами, версиями, именами собственными.
SEARCH_USE_BM25=true
# Адаптивный k: для перечислительных/сравнительных вопросов k увеличивается,
# для длинных и конкретных — уменьшается.
SEARCH_ADAPTIVE_K=true
# Multi-query: LLM генерирует ещё 2 формулировки, выдачи объединяются через
# RRF. Стоит +1 LLM вызов на поиск.
SEARCH_MULTI_QUERY=true
SEARCH_MULTI_QUERY_COUNT=3
# HyDE: для «определительных» запросов LLM генерирует короткий гипотетический
# ответ и мы ищем по его эмбеддингу.
SEARCH_HYDE=true
# Если средний score топа ниже порога — повторяем поиск с переформулированным
# запросом (1 раз). Шкала ≈ cosine.
SEARCH_LOW_SCORE_THRESHOLD=0.45
SEARCH_REFORMULATE_ON_LOW=true
# Запросы из преимущественно сущностей (даты, коды, артикулы) идут BM25-only.
SEARCH_ENTITY_BM25_FALLBACK=true

# --- Реранкер ---
# off — не реранкить, llm — через основную DeepSeek (без доп. установки),
# ce  — локальный cross-encoder (нужен sentence-transformers + torch)
RERANKER_PROVIDER=llm
RERANKER_CANDIDATES=20
RERANKER_CE_MODEL=BAAI/bge-reranker-v2-m3

# --- Качество ответа ---
# После ответа звать LLM ещё раз, чтобы сверить утверждения с найденными
# чанками. При расхождении — добавит к ответу короткое предупреждение.
ANSWER_VERIFICATION=true

# --- Лимиты ---
MAX_FILE_SIZE_MB=50
MAX_DOCUMENTS=100
MAX_HISTORY_MESSAGES=8

# Хранить оригиналы файлов после парсинга?
# true (default) — хранятся в data/uploads/{id}/. Нужно для перепарсинга
#   при апгрейде парсеров, для скачивания юзером, для аудита.
# false — удаляются сразу после успешной индексации. Экономия диска,
#   но потеряется возможность пере-обработать без перезагрузки файла.
KEEP_ORIGINAL_FILES=true

# --- Сервер ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# --- OCR ---
OCR_LANGUAGES=rus+eng
OCR_MIN_CHARS_PER_PAGE=100

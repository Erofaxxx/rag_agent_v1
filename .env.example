# --- LLM (DeepSeek через OpenRouter) ---
OPENROUTER_API_KEY=sk-or-v1-...
LLM_MODEL=deepseek/deepseek-chat
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000

# Опционально: заголовки для рейтинга на openrouter.ai
OPENROUTER_HTTP_REFERER=https://your-domain.com
OPENROUTER_X_TITLE=RAG Agent

# --- Аутентификация (HTTP Basic) ---
AUTH_USERNAME=admin
AUTH_PASSWORD=change_me_please

# --- Пути ---
DATA_DIR=./data

# --- Embedding (BGE-M3) ---
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_BATCH_SIZE=16
EMBEDDING_USE_FP16=true

# --- Чанкинг ---
CHUNK_SIZE=2400
CHUNK_OVERLAP=400

# --- Поиск ---
SEARCH_TOP_K=7
SEARCH_USE_BM25=false

# --- Лимиты ---
MAX_FILE_SIZE_MB=50
MAX_DOCUMENTS=100
MAX_HISTORY_MESSAGES=8

# --- Сервер ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# --- OCR ---
OCR_LANGUAGES=rus+eng
OCR_MIN_CHARS_PER_PAGE=100
